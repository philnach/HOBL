    <!--
         These tags will match any texture creations or mobile presents, so use priority=-1
         so that higher-level stack tags with better semantic understanding of the stack can capture instead.
         These will capture texture creations and mobile presents that haven't been captured
         by higher-level tags.
     -->
    <Tag Name="Uncategorized Texture Allocation" Priority="-1">
      <Entrypoint Module="D3D11.DLL" Method="CDevice::CreateTexture2D" />
    </Tag>
    <Tag Name="Uncategorized Mobile Present" Priority="-1">

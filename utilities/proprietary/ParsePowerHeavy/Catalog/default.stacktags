        <Entrypoint Module="System.Windows.ni.dll" Method="System.IO.IsolatedStorage.IsolatedStorageSettings::get_ApplicationSettings*" />
      </Tag>
    </Tag>

    <Tag Name="WriteableBitmap">
      <Tag Name="SaveJpeg">
        <Entrypoint Module="Microsoft.Phone.ni.dll" Method="System.Windows.Media.Imaging.Extensions::SaveJpeg" />
      </Tag>
      <Entrypoint Module="System.Windows.ni.dll" Method="System.Windows.Media.Imaging.WriteableBitmap*" />
    </Tag>

    <Tag Name="Networking">
      <Entrypoint Module="NPCtrl.dll" Method="COperatingSystemWebRequest::OperatingSystemWebRequestThreadFn" />
      <Entrypoint Module="NPCtrl.dll" Method="COperatingSystemWebRequest::Execute" />
      <Entrypoint Module="NPCtrl.dll" Method="CAsyncDownloadRequestManager::DownloadRequests" />
      <Entrypoint Module="NPCtrl.dll" Method="CommonBrowserHost::UnsecureDownload" />
    </Tag>


    <Tag Name="Animation">
      <Entrypoint Module="agcore.dll" Method="CTimeManager::Tick"/>
      <Entrypoint Module="agcore.dll" Method="CTimeManager::ProcessTickImpl"/>
      <Entrypoint Module="agcore.dll" Method="CCoreServices::FlushDeferredAnimationOperationQueue"/>
    </Tag>


    <Tag Name="Tick Manager">
      <Entrypoint Module="AGCore.dll" Method="CTickManager::DelayedTickThread" />
    </Tag>

    <Tag Name="Images">
      <Tag Name="Decode">
        <Entrypoint Module="NPCtrl.dll" Method="Decode"/>
      </Tag>
      <Tag Name="Cache">
        <Entrypoint Module="AGCore.dll" Method="CBitmapCacheManager::CImageDecodedUIExecutor::*" />
      </Tag>
    </Tag>

    <Tag Name="Elements">
      <Tag Name="Parsing">
        <Entrypoint Module="agcore.dll" Method="CParser::LoadXaml"/>
        <Entrypoint Module="agcore.dll" Method="CCoreServices::LoadXaml"/>
        <Entrypoint Module="agcore.dll" Method="CCoreServices::ParseXamlWithEventRoot"/>
        <Entrypoint Module="agcore.dll" Method="CCoreServices::ParseXamlWithExistingFrameworkRoot"/>
      </Tag>
      <Tag Name="Layout">
        <Tag Name="Measure">
          <Entrypoint Module="agcore.dll" Method="CUIElement::Measure"/>
        </Tag>
        <Tag Name="Arrange">
          <Entrypoint Module="agcore.dll" Method="CUIElement::Arrange"/>
        </Tag>
        <Entrypoint Module="agcore.dll" Method="CLayoutManager::UpdateLayout"/>
      </Tag>
    </Tag>

    <Tag Name="Media">
      <Tag Name="VideoProvider">
        <Entrypoint Module="NPCtrl.dll" Method="CWM7VideoSource::VideoProviderMessageProcWorkerStatic" />
      </Tag>
      <Tag Name="MSS">
        <Entrypoint Module="NPCtrl.dll" Method="CWM7ManagedSourceByteStream::ManagedSourceProcWorkerStatic" />
      </Tag>
    </Tag>


    <Tag Name="DirectManipulation">
      <Tag Name="Server">
        <Entrypoint Module="NPCtrl.dll" Method="CDirectManipulationServer::ServerThreadStatic" />
      </Tag>
      <Tag Name="Client">
        <Entrypoint Module="agcore.dll" Method="CDirectManipulationClient::UpdateValues" />
      </Tag>
    </Tag>

    <Tag Name="Resources">
      <Entrypoint Module="AGCore.dll" Method="CApplication::GetApplicationResource" />
    </Tag>

    <Tag Name="Text">
      <Tag Name="CTextBlock::EnsureTextView">
        <Entrypoint Module="AGCore.dll" Method="CTextBlock::EnsureTextView"/>
      </Tag>
      <Tag Name="Ptls5::LsCreateLineCore">
        <Entrypoint Module="AGCore.dll" Method="Ptls5::LsCreateLineCore"/>
      </Tag>
      <Tag Name="BlockLayoutEngine::Measure">
        <Entrypoint Module="AGCore.dll" Method="RichTextServices::Internal::BlockLayoutEngine::Measure"/>
      </Tag>
      <Tag Name="LsDisplayLine">
        <Entrypoint Module="AGCore.dll" Method="Ptls5::LsDisplayLine"/>
      </Tag>
      <Tag Name="ParseOpenTypeTables">
        <Entrypoint Module="NPCtrl.dll" Method="ParseOpenTypeTables"/>
      </Tag>
      <Tag Name="GlyphRun Bitmaps">
        <Entrypoint Module="AGCore.dll" Method="V5TextDrawingContext::BuildGlyphRunBitmaps"/>
      </Tag>
    </Tag>

    <Tag Name="Tracing">
      <Entrypoint Module="NPCtrl.dll" Method="CXcpWinCodeTracer_etw::IsTracingEnabled" />
    </Tag>

  </Tag>

  <Tag Name="Splash">
    <Tag Name="NavigateToModern">
      <Entrypoint Module="startmenu.dll" Method="NavigationProxy::NavigateToModern"/>
    </Tag>
    <Entrypoint Module="uixrender.dll" Method="*"/>
    <Entrypoint Module="uixn.dll" Method="Microsoft::Iris*"/>
  </Tag>

  <Tag Name="CoreCLR">
    <!--
         This tag will match many CLR allocations, so use priority=-1 so that higher-level
         stack tags with better semantic understanding of the stack can capture instead.
         This tag is meant to mean "managed allocations that aren't captured by other tags"
     -->
    <Tag Name="Uncategorized Allocation" Priority="-1">
      <Entrypoint Module="CORECLR.DLL" Method="Alloc" />
      <Entrypoint Module="CORECLR.DLL" Method="CExecutionEngine::ClrVirtualAlloc" />
      <Entrypoint Module="CORECLR.DLL" Method="EEHeapAllocInProcessHeap" />
    </Tag>
    <Tag Name="Garbage Collect">
      <Entrypoint Module="CORECLR.DLL" Method="WKS::GCHeap::GarbageCollect" />
    </Tag>
    <Tag Name="Finalizer">
      <Entrypoint Module="CORECLR.DLL" Method="WKS::GCHeap::FinalizerThreadStart" />
    </Tag>
  </Tag>

  <Tag Name="LINQ">
    <Entrypoint Module="SYSTEM.CORE.NI.DLL" Method="System.Linq.*"/>
  </Tag>
  <Tag Name="Newtonsoft.Json.WindowsPhone">
    <Entrypoint Module="Newtonsoft.Json.WindowsPhone.ni.dll" Method="*"/>
  </Tag>
  <Tag Name="Microsoft.Web.Media.SmoothStreaming">
    <Entrypoint Module="Microsoft.Web.Media.SmoothStreaming.ni.dll" Method="*"/>
  </Tag>
  <Tag Name="IdentityMine.WP.BaseViewModel">
    <Entrypoint Module="IdentityMine.WP.BaseViewModel.ni.dll" Method="*"/>
  </Tag>

  <!-- Stacks involving COM should remain under whichever component made the COM call if possible -->
  <!-- so we should use Priority -1 here -->
  <Tag Name="COM" Priority="-1">
    <Tag Name="QueryInterface" Priority="-1">
      <Entrypoint Module="combase.dll" Method="IUnknown_QueryInterface_Proxy" />
      <Entrypoint Module="combase.dll" Method="CRemoteUnknown::RemQueryInterface" />
    </Tag>
    <Tag Name="ASTAThreadSendReceive" Priority="-1">
      <Entrypoint Module="combase.dll" Method="ASTAThreadSendReceive" />
    </Tag>
    <Tag Name="ModernSTAThreadSendReceive" Priority="-1">
      <Entrypoint Module="combase.dll" Method="ModernSTAThreadSendReceive" />
    </Tag>
    <Tag Name="ASTAThreadWaitForCall" Priority="-1">
      <Entrypoint Module="combase.dll" Method="ASTAThreadWaitForCall" />
    </Tag>
    <Tag Name="ModernSTAThreadWaitForCall" Priority="-1">
      <Entrypoint Module="combase.dll" Method="ModernSTAThreadWaitForCall" />
    </Tag>
    <Tag Name="MarshalInterface" Priority="-1">
      <Entrypoint Module="combase.dll" Method="CoMarshalInterface" />
      <Entrypoint Module="rpcrt4.dll" Method="NdrPointerMarshall" />
    </Tag>
    <Tag Name="UnmarshalInterface" Priority="-1">
      <Entrypoint Module="combase.dll" Method="_CoUnmarshalInterface" />
      <Entrypoint Module="combase.dll" Method="UnmarshalObjRef" />
      <Entrypoint Module="rpcrt4.dll" Method="NdrpServerUnMarshal" />
    </Tag>
    <Tag Name="Release" Priority="-1">
      <Entrypoint Module="combase.dll" Method="IUnknown_Release_Proxy" />
      <Entrypoint Module="combase.dll" Method="CRemoteUnknown::RemRelease" />
    </Tag>
    <Tag Name="RoGetActivationFactory" Priority="-1">
      <Entrypoint Module="COMBASE.DLL" Method="RoGetActivationFactory"/>
    </Tag>
    <Tag Name="GetActivationFactory" Priority="-1">
      <Entrypoint Module="COMBASE.DLL" Method="CCGetWinRTRegisteredActivationFactory"/>
    </Tag>
    <Tag Name="GenerateRandomNumber" Priority="-1">
      <Entrypoint Module="COMBASE.DLL" Method="CRandomNumberGenerator::GenerateRandomNumber"/>
    </Tag>
    <Tag Name="GetRuntimeClassInfo" Priority="-1">
      <Entrypoint Module="COMBASE.DLL" Method="WinRTGetRuntimeClassInfo"/>
    </Tag>
    <Tag Name="ActivationProperties" Priority="-1">
      <Entrypoint Module="COMBASE.DLL" Method="ActivationProperties*"/>
    </Tag>
    <!-- This is -2 priority because it sits below some of the COM methods above -->
    <Tag Name="Uncategorized COM" Priority="-2">
      <Entrypoint Module="combase.dll" Method="ObjectStubless*" />
    </Tag>
  </Tag>

  <!-- The callee functions of this HintTag are real RPC server side routines. -->
  <!-- Their module names will be automatically created as StackTags. -->
  <HintTag Name="RPC" HintOperator="Callee" OnlyShowModule="false">
    <Entrypoint Module="rpcrt4.dll" Method="Invoke_epilog1_start"/>
    <Entrypoint Module="rpcrt4.dll" Method="Invoke"/>
  </HintTag>
  <!-- comment this caller HintTag as a sample
  <HintTag Name="AllocateHeap" HintOperator="Caller">
    <Entrypoint Module="ntdll.dll" Method="RtlAllocateHeap"/>
  </HintTag>
  -->

</Tag>
